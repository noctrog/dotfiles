# BEGIN DOTFILES THEME
# Catppuccin Mocha
set notification-error-bg       "#f38ba8"
set notification-error-fg       "#1e1e2e"
set notification-warning-bg     "#fab387"
set notification-warning-fg     "#1e1e2e"
set notification-bg             "#1e1e2e"
set notification-fg             "#cdd6f4"

set completion-bg               "#1e1e2e"
set completion-fg               "#cdd6f4"
set completion-group-bg         "#1e1e2e"
set completion-group-fg         "#89b4fa"
set completion-highlight-bg     "#45475a"
set completion-highlight-fg     "#cdd6f4"

set index-bg                    "#1e1e2e"
set index-fg                    "#cdd6f4"
set index-active-bg             "#45475a"
set index-active-fg             "#cdd6f4"

set inputbar-bg                 "#1e1e2e"
set inputbar-fg                 "#cdd6f4"
set statusbar-bg                "#181825"
set statusbar-fg                "#cdd6f4"

set highlight-color             "#f9e2af"
set highlight-active-color      "#89b4fa"

set default-bg                  "#1e1e2e"
set default-fg                  "#cdd6f4"

set render-loading              true
set render-loading-fg           "#1e1e2e"
set render-loading-bg           "#cdd6f4"

set recolor-lightcolor          "#1e1e2e"
set recolor-darkcolor           "#cdd6f4"
# END DOTFILES THEME

# Startup options
#
#
set adjust-open width
set recolor true

map <Left> navigate previous
map <Right> navigate next
map <C-=> zoom in
map <C--> zoom out
map B jumplist backward
map b jumplist forward
